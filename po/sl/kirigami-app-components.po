#: actioncollection/keysequencehelper.cpp:134
#, kde-format
msgctxt "@title:dialog"
msgid "Reserved Shortcut"
msgstr "Rezervirana bližnjica"

#: actioncollection/keysequencehelper.cpp:136
#, kde-format
msgctxt "@info"
msgid ""
"The F12 key is reserved on Windows, so cannot be used for a global "
"shortcut.\n"
"Please choose another one."
msgstr ""
"Tipka F12 je rezervirana v sistemu Windows, zato je ni mogoče uporabiti za "
"globalno bližnjico.\n"
"Izberite drugo."

#: actioncollection/keysequencehelper.cpp:160
#, kde-format
msgctxt ""
"@title:dialog This happen when a global shortcut is already defined with the "
"same shortcut"
msgid "Global Shortcut Shadowing"
msgstr "Globalno senčenje bližnjic"

#: actioncollection/keysequencehelper.cpp:163
#, kde-format
msgctxt "@info"
msgid "The '%1' key combination is shadowed by following global actions:\n"
msgstr "Kombinacijo tipk '%1' zasenčijo naslednja globalna dejanja:\n"

#: actioncollection/keysequencehelper.cpp:165
#: actioncollection/keysequencehelper.cpp:171
#, kde-format
msgctxt "@info"
msgid "Action '%1' in context '%2'\n"
msgstr "Dejanje '%1' v kontekstu '%2'\n"

#: actioncollection/keysequencehelper.cpp:169
#, kde-format
msgctxt "@info"
msgid "The '%1' key combination shadows following global actions:\n"
msgstr "Kombinacija tipk '%1' povzroča senco za naslednja globalna dejanja:\n"

#: actioncollection/keysequencehelper.cpp:220
#, kde-format
msgctxt "@title:dialog"
msgid "Conflict with existing Shortcut"
msgstr "Konflikt z obstoječo bližnjico"

#: actioncollection/keysequencehelper.cpp:222
#, kde-format
msgctxt "@info"
msgid ""
"The '%1' key combination is already used for the action \"%2\".\n"
"Do you really want to use the shortcut here instead??"
msgstr ""
"Kombinacija tipk '%1' je že uporabljena za dejanje \"%2\".\n"
"Ali res želite namesto tega uporabiti bližnjico tukaj?"

#: actioncollection/keysequencehelper.cpp:239
#, kde-format
msgctxt "@title:dialog"
msgid "Conflict with Standard Application Shortcut"
msgstr "Konflikt s standardno bližnjico aplikacije"

#: actioncollection/keysequencehelper.cpp:241
#, kde-format
msgctxt "@info"
msgid ""
"The '%1' key combination is also used for the standard action \"%2\" that "
"some applications use.\n"
"Do you really want to use it as a global shortcut as well?"
msgstr ""
"Kombinacija tipk '%1' se uporablja tudi za standardno dejanje \"%2\", ki ga "
"uporabljajo nekatere aplikacije.\n"
"Ali jo res želite uporabiti tudi kot globalno bližnjico?"

