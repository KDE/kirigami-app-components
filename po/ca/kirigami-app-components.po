msgid "Default: None"
msgstr "Predeterminat: sense"

#: actioncollection/qml/KeySequenceItem.qml:116
#, kde-format
msgctxt "Default shortcut label"
msgid "Default: %1"
msgstr "Predeterminat: %1"

#: actioncollection/qml/KeySequenceItem.qml:171
#, kde-format
msgctxt "What the user inputs now will be taken as the new shortcut"
msgid "Input"
msgstr "Entrada"

#: actioncollection/qml/KeySequenceItem.qml:172
#, kde-format
msgctxt "No shortcut defined"
msgid "None"
msgstr "Cap"

#: actioncollection/qml/KeySequenceItem.qml:183
#, kde-format
msgid ""
"Click on the button, then enter the shortcut like you would in the program.\n"
"Example for Ctrl+A: hold the Ctrl key and press A."
msgstr ""
"Cliqueu en el botó, llavors introduïu la drecera com ho faríeu en el "
"programa.\n"
"Exemple per a Ctrl+a: manteniu premuda la tecla «Ctrl» mentre premeu la «a»."

#: actioncollection/qml/KeySequenceItem.qml:224
#, kde-format
msgctxt "@info:tooltip"
msgid "Clear Key Sequence"
msgstr "Neteja la seqüència de tecles"

#: actioncollection/qml/KeySequenceItem.qml:240
#, kde-format
msgctxt "@info:tooltip"
msgid "Cancel Key Sequence Recording"
msgstr "Cancel·la l'enregistrament de la seqüència de tecles"

